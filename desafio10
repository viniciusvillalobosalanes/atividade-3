"""
Uma única estrutura global gera alto acoplamento.
Quanto mais o sistema cresce, mais difícil fica manter o controle do estado.
"""

class SistemaHospitalar:
    def __init__(self):
        # Estado centralizado do sistema
        self.pacientes = []
        self.medicos = []
        self.leitos_disponiveis = 5
        self.caixa_financeiro = 0


def realizar_internacao(sistema, paciente, valor):
    # Procedimento que altera diretamente o estado recebido
    if sistema.leitos_disponiveis > 0:
        sistema.pacientes.append(paciente)
        sistema.leitos_disponiveis -= 1
        sistema.caixa_financeiro += valor
        print(f"Paciente {paciente} internado com sucesso.")
    else:
        print("Sem leitos disponíveis.")


# Simulação
hospital = SistemaHospitalar()
realizar_internacao(hospital, "João", 5000)
realizar_internacao(hospital, "Maria", 7000)

print("Pacientes:", hospital.pacientes)
print("Leitos disponíveis:", hospital.leitos_disponiveis)
print("Caixa financeiro:", hospital.caixa_financeiro)